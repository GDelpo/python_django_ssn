# ============================================================================
# SSN Django — Variables de entorno
# ============================================================================
# Copiar a .env y completar los valores marcados como "Requerido".
# Nunca commitear el .env real.
# ============================================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=False
SECRET_KEY=                          # Requerido. Generar: openssl rand -hex 32
ALLOWED_HOSTS="localhost,127.0.0.1,192.168.190.95"

# --- Superusuario (solo modo local, cuando IDENTITY_SERVICE_URL está vacío) ---
DJANGO_SUPERUSER_EMAIL=sistemas@nobleseguros.com
DJANGO_SUPERUSER_PASSWORD=           # Requerido
DJANGO_SUPERUSER_FIRST_NAME=Admin
DJANGO_SUPERUSER_LAST_NAME=Sistemas

# --- API SSN ---
SSN_API_USERNAME=                    # Requerido. Credenciales Noble ante SSN
SSN_API_PASSWORD=                    # Requerido
SSN_API_CIA=                         # Requerido. Código de compañía Noble
SSN_API_BASE_URL=https://ri.ssn.gob.ar/api   # Producción. Test: https://testri.ssn.gob.ar/api
SSN_API_MAX_RETRIES=3
SSN_API_RETRY_DELAY=5

# --- PostgreSQL ---
POSTGRES_DB=ssn_db
POSTGRES_USER=ssn_user
POSTGRES_PASSWORD=                   # Requerido
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Compañía ---
COMPANY_NAME="Noble Seguros"
COMPANY_WEBSITE="https://www.nobleseguros.com"
COMPANY_LOGO_URL="https://www.nobleseguros.com/logo.png"
COMPANY_FAVICON_URL="https://www.nobleseguros.com/favicon.ico"

# --- Soporte ---
SUPPORT_EMAIL=sistemas@nobleseguros.com

# --- Alertas por email ---
ALERT_EMAIL_TO=sistemas@nobleseguros.com
BASE_URL=http://192.168.190.95

# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=              # Misma API key que mailsender
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@nobleseguros.com

# --- Autenticación ---
# Vacío = modo local (BD de Django). Con URL = usa el servicio identidad
IDENTITY_SERVICE_URL=http://identidad_api:8080
IDENTITY_SERVICE_VERIFY_SSL=False

# --- SSL / Nginx (standalone) ---
SSL_DOMAIN=192.168.190.95
SSL_IP=192.168.190.95
SSL_COUNTRY=AR
NGINX_HOST=0.0.0.0
NGINX_PORT_HTTP=80
NGINX_PORT_HTTPS=443

# --- Standalone sin Nginx ---
WEB_PORT=8000
WEB_HOST=127.0.0.1

# --- Permisos de volumen ---
LOCAL_UID=1001
LOCAL_GID=1001

# --- Misc ---
PROJECT_VERSION=latest
# CSRF_EXTRA_ORIGINS=
