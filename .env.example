# ============================================================================
# SSN Django — Environment variables
# ============================================================================
# Copy to .env and fill in the values marked as "Required".
# Never commit the real .env.
# ============================================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=False
SECRET_KEY=                          # Required. Generate: openssl rand -hex 32
ALLOWED_HOSTS="localhost,127.0.0.1,your-domain.example.com"

# --- Superuser (only local mode, when IDENTITY_SERVICE_URL is empty) ---
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=           # Required
DJANGO_SUPERUSER_FIRST_NAME=Admin
DJANGO_SUPERUSER_LAST_NAME=User

# --- SSN API ---
# Credentials provided by SSN (Superintendencia de Seguros de la Nación, Argentina)
SSN_API_USERNAME=your-ssn-username   # Required
SSN_API_PASSWORD=                    # Required
SSN_API_CIA=your-company-code        # Required. SSN company code
SSN_API_BASE_URL=https://ri.ssn.gob.ar/api   # Production. Test: https://testri.ssn.gob.ar/api
SSN_API_MAX_RETRIES=3
SSN_API_RETRY_DELAY=5

# --- PostgreSQL ---
POSTGRES_DB=ssn_db
POSTGRES_USER=ssn_user
POSTGRES_PASSWORD=                   # Required. Generate: openssl rand -hex 32
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Company branding (shown in templates) ---
COMPANY_NAME="Your Company"
COMPANY_WEBSITE="https://www.example.com"
COMPANY_LOGO_URL="https://www.example.com/logo.png"
COMPANY_FAVICON_URL="https://www.example.com/favicon.ico"

# --- Support ---
SUPPORT_EMAIL=support@example.com

# --- Email alerts ---
ALERT_EMAIL_TO=alerts@example.com
BASE_URL=https://your-domain.example.com

# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=               # SMTP / provider API key
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@example.com

# --- Authentication ---
# Empty = local mode (Django DB). With URL = delegates to an identity service
IDENTITY_SERVICE_URL=
IDENTITY_SERVICE_VERIFY_SSL=False

# --- SSL / Nginx (standalone) ---
SSL_DOMAIN=your-domain.example.com
SSL_IP=127.0.0.1
SSL_COUNTRY=AR
NGINX_HOST=0.0.0.0
NGINX_PORT_HTTP=80
NGINX_PORT_HTTPS=443

# --- Standalone without Nginx ---
WEB_PORT=8000
WEB_HOST=127.0.0.1

# --- Volume permissions ---
LOCAL_UID=1000
LOCAL_GID=1000

# --- Misc ---
PROJECT_VERSION=latest
# CSRF_EXTRA_ORIGINS=
